# =============================================================================
# LOYALINK ENVIRONMENT VARIABLES
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For local development, you can use PostgreSQL or SQLite
# For production (Vercel), use Vercel Postgres
# Required: Yes
DATABASE_URL="postgresql://user:password@localhost:5432/loyalink?schema=public"

# Example for local SQLite (development only):
# DATABASE_URL="file:./dev.db"

# Example for local PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/loyalink?schema=public"

# Example for Vercel Postgres (will be auto-populated by Vercel):
# DATABASE_URL="postgres://default:xxxxx@xxxxx.postgres.vercel-storage.com/verceldb"

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Environment mode: development, test, or production
# Required: No (defaults to development)
NODE_ENV="development"

# Skip environment variable validation (for build processes)
# Required: No
# SKIP_ENV_VALIDATION=true

# -----------------------------------------------------------------------------
# Security Configuration (Production)
# -----------------------------------------------------------------------------
# Add these in production for enhanced security:
# NEXTAUTH_SECRET="your-secret-key-here"
# NEXTAUTH_URL="https://your-domain.com"
